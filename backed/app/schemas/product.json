{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProductSchema",
  "description": "Esquema estructurado del producto cargado desde Excel por el vendedor dropshipping",
  "type": "object",
  "required": [
    "product_id",
    "name",
    "category",
    "price",
    "currency",
    "stock_status",
    "min_shipping_days",
    "max_shipping_days"
  ],
  "properties": {
    "product_id": {
      "type": "string",
      "minLength": 1,
      "description": "Identificador único del producto"
    },
    "name": {
      "type": "string",
      "minLength": 3,
      "description": "Nombre del producto"
    },
    "category": {
      "type": "string",
      "minLength": 2,
      "description": "Categoría del producto"
    },
    "price": {
      "type": "number",
      "minimum": 0,
      "description": "Precio del producto"
    },
    "currency": {
      "type": "string",
      "enum": ["COP", "USD", "EUR"],
      "description": "Moneda del producto"
    },
    "stock_status": {
      "type": "string",
      "enum": ["in_stock", "out_of_stock", "limited", "preorder"],
      "description": "Estado del inventario"
    },
    "min_shipping_days": {
      "type": "integer",
      "minimum": 0,
      "description": "Tiempo mínimo de envío"
    },
    "max_shipping_days": {
      "type": "integer",
      "minimum": 0,
      "description": "Tiempo máximo de envío"
    },
    "short_description": {
      "type": "string",
      "description": "Descripción corta del producto"
    },
    "full_description": {
      "type": "string",
      "description": "Descripción completa del producto"
    },
    "brand": {
      "type": "string",
      "description": "Marca del producto"
    },
    "shipping_cost": {
      "type": "number",
      "minimum": 0,
      "description": "Costo de envío"
    },
    "shipping_regions": {
      "type": "string",
      "description": "Regiones o ciudades donde aplica el envío"
    },
    "returns_policy": {
      "type": "string",
      "description": "Política de devoluciones"
    },
    "warranty_policy": {
      "type": "string",
      "description": "Política de garantía"
    },
    "specs": {
      "type": "string",
      "description": "Especificaciones técnicas del producto"
    },
    "variants": {
      "type": "string",
      "description": "Variantes del producto"
    },
    "source": {
      "type": "string",
      "description": "Proveedor u origen del producto"
    }
  }
}