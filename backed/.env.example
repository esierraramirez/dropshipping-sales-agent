# ==============================================================================
# CONFIGURACIÓN DE OPENAI - OPTIMIZADO PARA BAJO COSTO Y BAJA LATENCIA
# ==============================================================================

# Modelo: gpt-5.4-nano es el más económico (recomendado para chat)
# Opciones: gpt-5.4-nano, gpt-5.4-mini (más potente), gpt-5.4 (premium)
OPENAI_MODEL=gpt-5.4-nano

# Razonamiento: "none" desactiva la cadena de pensamiento (60-80% menos tokens)
# Opciones: none (recomendado), low
OPENAI_REASONING_EFFORT=none

# Verbosidad: "low" = respuestas concisas (ideal para chat)
# Opciones: low (recomendado), medium, high
OPENAI_VERBOSITY=low

# Límites de tokens
OPENAI_MAX_INPUT_TOKENS=1000        # Contexto máximo: 1000 caracteres aprox
OPENAI_MAX_OUTPUT_TOKENS=300         # Respuestas limitadas a 300 tokens

# ==============================================================================
# CONFIGURACIÓN DE BASE DE DATOS
# ==============================================================================
DATABASE_URL=postgresql://postgres:Negritomotero%24123@db.zywqomqbvxuwbksigcmp.supabase.co:5432/postgres

# ==============================================================================
# CONFIGURACIÓN JWT / AUTENTICACIÓN
# ==============================================================================
JWT_SECRET=your-super-secret-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ==============================================================================
# CONFIGURACIÓN WHATSAPP
# ==============================================================================
WHATSAPP_API_VERSION=v23.0

# ==============================================================================
# VARIABLE DE ENTORNO
# ==============================================================================
ENV=dev
APP_NAME=Dropshipping Sales Agent API
